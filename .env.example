# Telegram bot token from @BotFather
BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPabcdefghijklmnop

# Your Telegram user ID(s) — comma separated (get from @userinfobot)
ADMIN_IDS=123456789,987654321

# Private channel ID — must start with -100
# Bot ko us channel ka Admin banana zaroori hai
PRIVATE_CHANNEL_ID=-1001234567890

# 8 xapiverse.com API keys — comma separated
XAPI_KEYS=key1,key2,key3,key4,key5,key6,key7,key8

# Render automatically sets RENDER_EXTERNAL_URL — aapko manually set karne ki zaroorat NAHI
# Local testing ke liye set karo:
# PUBLIC_URL=http://localhost:8000

# Port (Render 10000 prefer karta hai)
PORT=10000
